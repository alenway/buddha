#!/bin/bash

echo "🧹 [Step 1/2] Auto-formatting your Next.js code..."
npx prettier --write .
git add .

echo "🚀 [Step 2/2] Checking Next.js files for linting errors..."
if ! pnpm run lint; then
    echo "❌ Next.js linting failed. Please fix the errors before committing."
    exit 1 
fi

echo "✅ Everything looks amazing! Proceeding with commit..."
exit 0